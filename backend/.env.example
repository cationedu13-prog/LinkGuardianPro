# ============================================================
# LinkGuardian Pro – Environment Variables
# Copy this file to .env for local development
# Set all these as Railway environment variables for production
# ============================================================

# ── Flask ────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=generate-a-64-char-random-string-here
FLASK_ENV=production

# ── Supabase ─────────────────────────────────────────────────
# From: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-supabase-anon-public-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# ── Cron Security ────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Also add this exact value as a GitHub Secret named CRON_API_KEY
CRON_API_KEY=generate-another-random-string-here

# ── Telegram Alerts ──────────────────────────────────────────
# From: Telegram → @BotFather → /newbot
TELEGRAM_BOT_TOKEN=123456789:ABCDefGhIJKlmNoPQRstuVwXyz

# ── Email (Password Reset) ────────────────────────────────────
# Gmail: Enable 2FA → Google Account → App Passwords → Generate
# Or use any SMTP provider (SendGrid, Resend, Brevo etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
FROM_EMAIL=your-email@gmail.com

# ── Optional: ScraperAPI (Layer 2 detection) ─────────────────
# From: scraperapi.com → Dashboard → API Key
# Leave empty to skip Layer 2
SCRAPER_API_KEY=

# ── Optional: Playwright (Layer 3 detection) ─────────────────
# Set to true only on Railway paid plan (needs more RAM)
ENABLE_PLAYWRIGHT=false

# ── Frontend ─────────────────────────────────────────────────
# Your Vercel deployment URL (for CORS + password reset emails)
FRONTEND_URL=https://your-project.vercel.app

# ── Rate Limiting ─────────────────────────────────────────────
FREE_CHECKER_LIMIT=10

# ── GitHub Actions (add as GitHub Secrets, not here) ─────────
# BACKEND_URL = your Railway URL  e.g. https://your-app.up.railway.app
# CRON_API_KEY = same value as above
